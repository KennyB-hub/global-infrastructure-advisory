{
  "policyId": "oge-misconduct-reporting",
  "title": "Office of Government Ethics (OGE) — Where to Report Misconduct and Conflict of Interest",
  "authority": "Office of Government Ethics (OGE), Executive Branch",
  "regulationNumber": "5 CFR Part 2635",
  "version": "2.0",
  "effectiveDate": "2023-01-01",
  "scope": "GIA employee conduct, conflict of interest disclosure, and misconduct reporting",
  "description": "Establishes mandatory reporting requirements for government employees and contractors regarding ethics violations, misconduct, and conflicts of interest",
  "principles": [
    {
      "id": "ETH-001",
      "title": "Public Service Integrity",
      "description": "All employees must prioritize public interest over personal gain",
      "requirement": "mandatory"
    },
    {
      "id": "ETH-002",
      "title": "Conflict of Interest Avoidance",
      "description": "Employees must disclose and recuse from situations with conflicts",
      "requirement": "mandatory"
    },
    {
      "id": "ETH-003",
      "title": "Mandatory Reporting",
      "description": "Suspected misconduct must be reported immediately",
      "requirement": "mandatory"
    },
    {
      "id": "ETH-004",
      "title": "Protected Reporting",
      "description": "Reporters must be protected from retaliation",
      "requirement": "mandatory"
    },
    {
      "id": "ETH-005",
      "title": "Transparency and Accountability",
      "description": "Ethics violations must be investigated and acted upon",
      "requirement": "mandatory"
    }
  ],
  "applicablePersonnel": [
    "GIA employees",
    "contractors-with-federal-authority",
    "interns-and-fellows",
    "special-government-employees",
    "board-members"
  ],
  "conflictOfInterestTypes": [
    {
      "type": "financial-interest",
      "description": "Stocks, partnerships, loans, gifts in regulated companies",
      "disclosureRequired": true,
      "recusalRequired": true
    },
    {
      "type": "employment-relationships",
      "description": "Relatives employed by regulated entities",
      "disclosureRequired": true,
      "recusalRequired": "case-dependent"
    },
    {
      "type": "outside-activities",
      "description": "Consulting, speaking, board service",
      "disclosureRequired": true,
      "approvalRequired": "case-dependent"
    },
    {
      "type": "gifts-and-entertainment",
      "description": "Gifts, meals, travel from prohibited sources",
      "restrictionLevel": "prohibited"
    },
    {
      "type": "future-employment",
      "description": "Negotiations with companies involved in current decisions",
      "disclosureRequired": true,
      "recusalRequired": true
    }
  ],
  "misconduct": {
    "types": [
      "fraud-or-misappropriation",
      "falsification-of-records",
      "unauthorized-disclosure-of-information",
      "conflict-of-interest-violation",
      "abuse-of-authority",
      "gross-mismanagement",
      "violation-of-law-or-regulation"
    ],
    "mustReport": true,
    "timeline": "immediately"
  },
  "reportingChannels": [
    {
      "channel": "immediate-supervisor",
      "applicability": "non-serious-concerns",
      "priority": "first-attempt"
    },
    {
      "channel": "agency-ethics-office",
      "applicability": "all-concerns",
      "priority": "always-available"
    },
    {
      "channel": "inspector-general",
      "applicability": "serious-misconduct",
      "priority": "for-fraud-or-waste"
    },
    {
      "channel": "office-of-government-ethics",
      "applicability": "ethics-violations",
      "priority": "for-systemic-issues"
    },
    {
      "channel": "designated-agency-ethics-counselor",
      "applicability": "confidential-consultation",
      "priority": "for-advice"
    },
    {
      "channel": "merit-systems-protection-board",
      "applicability": "whistleblower-protection",
      "priority": "if-retaliation-feared"
    },
    {
      "channel": "office-of-special-counsel",
      "applicability": "whistleblower-protection",
      "priority": "if-retaliation-feared"
    }
  ],
  "disclosure": {
    "requiredForms": [
      "SF-278-Executive-Branch-Personnel-Public-Financial-Disclosure",
      "OGE-Form-450-Confidential-Financial-Disclosure"
    ],
    "frequency": "annual-and-upon-change",
    "penalties": {
      "failure-to-disclose": "civil-penalties-up-to-50k",
      "false-disclosure": "criminal-penalties"
    }
  },
  "trustZoneApplicability": {
    "Public": "not-applicable",
    "Farmer": "not-applicable",
    "Contractor": "limited-disclosure-required",
    "Employee": "full-disclosure-required",
    "Admin": "enhanced-disclosure-required",
    "Gov": "enhanced-disclosure-required",
    "DeepGov": "maximum-transparency-required"
  },
  "controls": [
    {
      "control": "ETH-CTL-001",
      "description": "Mandatory ethics training for all employees",
      "frequency": "annual"
    },
    {
      "control": "ETH-CTL-002",
      "description": "Automated conflict of interest screening",
      "checkType": "real-time-on-assignment"
    },
    {
      "control": "ETH-CTL-003",
      "description": "Anonymous reporting hotline",
      "availability": "24/7"
    },
    {
      "control": "ETH-CTL-004",
      "description": "Retaliation protection monitoring",
      "checkType": "continuous"
    },
    {
      "control": "ETH-CTL-005",
      "description": "Investigation tracking and case management",
      "auditTrail": "complete-and-confidential"
    }
  ],
  "retaliation": {
    "prohibited": true,
    "protectedActivities": [
      "reporting-misconduct",
      "refusing-illegal-orders",
      "cooperating-with-investigations",
      "filing-grievances",
      "disclosing-classified-information-to-inspectors-general"
    ],
    "reportRetaliation": "immediately-to-IG-or-OSC"
  },
  "penalties": {
    "misconduct": "termination-and-criminal-prosecution",
    "conflict-of-interest": "removal-or-disciplinary-action",
    "false-reporting": "disciplinary-action-up-to-termination",
    "retaliation": "removal-and-damages"
  },
  "references": [
    "https://www.oge.gov/web/oge.nsf/",
    "5 CFR Part 2635 (Standards of Ethical Conduct)",
    "5 USC 7211 (Whistleblower Protection)",
    "Whistleblower Protection Act of 1989",
    "Dodd-Frank Act (Securities Whistleblower)",
    "GIA CONSTITUTION.md Article III"
  ],
  "lastReviewed": "2026-05-13",
  "nextReview": "2027-05-13"
}
