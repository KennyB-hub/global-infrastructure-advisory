{
  "policyVersion": "v1",
  "retention": {
    "session": {
      "hotDays": 7,
      "warmDays": 30,
      "coldDays": 0
    },
    "telemetry": {
      "hotDays": 3,
      "warmDays": 30,
      "coldDays": 0
    },
    "memory": {
      "hotDays": 14,
      "warmDays": 60,
      "coldDays": 0
    },
    "audit": {
      "hotDays": 0,
      "warmDays": 365,
      "coldDays": 3650
    }
  },
  "deletionRules": {
    "mode": "soft-then-hard",
    "softDeleteDays": 7,
    "hardDeleteAfterSoftDays": 30
  },
  "compliance": {
    "requiresApprovalForAuditDeletion": true,
    "approvalRoles": ["system-admin", "compliance-admin"],
    "logDeletionEventsToAudit": true
  }
}
