public sealed class PolicyDefinition
{
    public string PolicyId { get; set; } = default!;
    public string Name { get; set; } = default!;
    public string Version { get; set; } = "1.0.0";
    public string Source { get; set; } = default!; // e.g. "OMB_M-14-06"
    public PolicyScope Scope { get; set; } = new();
    public List<PolicyRule> Rules { get; set; } = new();
    public Dictionary<string, string> Metadata { get; set; } = new();
}

public sealed class PolicyScope
{
    public string[] ResourceTypes { get; set; } = Array.Empty<string>(); // DATASET|MODEL|...
    public string[] Actions { get; set; } = Array.Empty<string>();       // READ|WRITE|...
    public string[] TrustZones { get; set; } = Array.Empty<string>();    // gov|deepgov|...
}

public sealed class PolicyRule
{
    public string RuleId { get; set; } = default!;
    public string Description { get; set; } = default!;
    public string Condition { get; set; } = default!; // expression string
    public string Effect { get; set; } = default!;    // ALLOW|DENY|CONDITION
}
