{
  "specId": "rural-node-v1",
  "description": "Standard specification for rural infrastructure nodes in the sovereign grid.",
  "version": "v1",
  "constraints": {
    "connectivity": {
      "primary": ["cellular", "satellite"],
      "offlineToleranceMinutes": 1440,
      "supportsDelayedSync": true
    },
    "power": {
      "supportsMicrogrid": true,
      "supportsBackupGenerator": true,
      "supportsBattery": true
    }
  },
  "capabilities": {
    "localCaching": true,
    "localDecisionMaking": true,
    "offlineOperation": true,
    "contractorDispatch": true
  },
  "endpoints": {
    "localStatus": "/local/status",
    "localLogs": "/local/logs",
    "syncUp": "/sync/up",
    "syncDown": "/sync/down"
  },
  "logging": {
    "requiredLogTypes": ["session", "telemetry", "memory"],
    "syncStrategy": "delayed-batch",
    "conflictResolution": "last-write-wins-with-audit"
  }
}
