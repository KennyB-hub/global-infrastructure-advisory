{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",

    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "allowJs": true,
    "checkJs": false,

    "baseUrl": ".",
    "paths": {
      "*": ["./*"]
    },

    "outDir": "dist",
    "rootDir": "."
  },

  "include": [
    "seven-os/platform/**/*",
    "seven-os/backend/**/*",
    "seven-os/ai/**/*",
    "seven-os/system/**/*",
    "seven-os/runtime/**/*",
    "seven-os/autonomous-os/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "public"
  ]
}
