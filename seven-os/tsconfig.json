{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "rootDir": "."
  },
  "include": [
    "**/*",
    "../proprietary-cli/**/*",
    "../scripts/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
