{
  "system": {
    "id": "deep-mind-v12",
    "env": "enterprise-gov",
    "heartbeat_interval": "1000ms"
  },
  "security": {
    "trust_zones": ["public", "internal", "vault"],
    "enforce_schema": true,
    "audit_logs": "seven-os/data/logs"
  },
  "ai_sandbox": {
    "enabled": true,
    "mode": "validation-only",
    "max_token_budget": 500
  }
}
