{
  "policyId": "ENERGY_GRID_STABILITY_V2",
  "name": "Grid Stability Policy Pack",
  "version": "2.0.0",
  "source": "AIEE",
  "scope": {
    "resourceTypes": ["GRID", "SUBSTATION", "LINE", "BUS"],
    "actions": ["CONTROL", "SWITCH", "DISPATCH", "BLACKSTART"],
    "trustZones": ["public", "contractor", "employee", "admin", "gov", "deepgov", "system"]
  },
  "rules": [
    {
      "ruleId": "GRID_FREQ_001",
      "description": "Prevent unsafe frequency excursions.",
      "condition": "data.gridFrequency < ai.globalCode.energy.grid.minFrequency || data.gridFrequency > ai.globalCode.energy.grid.maxFrequency || ai.giiContext.systemicRiskScore > 0.7 || ai.autonomy.level < 2",
      "effect": "DENY"
    },
    {
      "ruleId": "GRID_FREQ_002",
      "description": "Rapid frequency deviation requires human review.",
      "condition": "Math.abs(data.freqDeltaPerSecond) > ai.globalCode.energy.grid.maxFreqDeltaPerSecond || ai.giiContext.cascadingFailureRisk == true || ai.autonomy.level < 2",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "GRID_VOLT_001",
      "description": "Prevent unsafe bus voltage levels.",
      "condition": "data.busVoltage < ai.globalCode.energy.grid.minVoltageKv || data.busVoltage > ai.globalCode.energy.grid.maxVoltageKv || ai.giiContext.sectorRiskScore > 0.75 || ai.autonomy.level < 1",
      "effect": "DENY"
    },
    {
      "ruleId": "GRID_LOAD_001",
      "description": "Prevent line overload beyond thermal rating.",
      "condition": "data.lineLoadingPercent > ai.globalCode.energy.grid.maxLineLoadingPercent || ai.giiContext.cascadingFailureRisk == true || ai.autonomy.level < 2",
      "effect": "DENY"
    },
    {
      "ruleId": "GRID_LOAD_002",
      "description": "Emergency loading requires human review.",
      "condition": "data.lineLoadingPercent > ai.globalCode.energy.grid.emergencyLoadingPercent && data.emergencyMode == true || ai.giiContext.systemicRiskScore > 0.8 || ai.autonomy.level < 2",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "GRID_TOPO_001",
      "description": "Prevent unintentional islanding.",
      "condition": "data.isIslandingRisk == true && action.name == \"OpenBreaker\" || ai.giiContext.cascadingFailureRisk == true || ai.autonomy.level < 2",
      "effect": "DENY"
    },
    {
      "ruleId": "GRID_TOPO_002",
      "description": "Critical bus switching requires human review.",
      "condition": "data.busCritical == true && action.name == \"OpenBreaker\" || ai.giiContext.systemicRiskScore > 0.85 || ai.autonomy.level < 2",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "GRID_BLACKSTART_001",
      "description": "Blackstart restricted to deepgov/system with high autonomy.",
      "condition": "action.name == \"Blackstart\" && (actor.trustZone != \"deepgov\" && actor.trustZone != \"system\") || ai.autonomy.level < 3 || ai.giiContext.systemicRiskScore > 0.9",
      "effect": "DENY"
    }
  ]
}
