{
  "moduleId": "war-zone-humanitarian-module-v1",
  "version": "v1",
  "objectives": [
    "protect civilians",
    "maintain critical infrastructure",
    "support humanitarian aid",
    "coordinate safe corridors",
    "stabilize microgrids + water systems"
  ],
  "inputs": {
    "conflictMap": "regions tagged war-zone",
    "humanitarianNeeds": "water, shelter, medical, power",
    "NGOProfiles": "capabilities + deployment readiness",
    "microgridStatus": "battery, solar, generator, load",
    "publicWorkforce": "local responders",
    "contractors": "in-region skilled labor"
  },
  "outputs": {
    "safeCorridors": "routes for civilians + aid",
    "infrastructurePriorities": "water, power, comms",
    "deploymentPlan": "NGOs + responders",
    "microgridDirectives": "island mode, rationing",
    "evacuationSupport": "transport + shelter routing"
  },
  "safety": {
    "requiresHumanApproval": [
      "evacuation-orders",
      "cross-border-actions",
      "resource-diversion"
    ]
  },
  "logging": {
    "requires": ["session", "audit", "telemetry"],
    "mustSignDecisions": true
  }
}
