{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cyber Workforce Profile",
  "description": "Workforce schema for cyber security professionals in GIA.",
  "type": "object",
  "required": ["id", "name", "role", "skills", "certifications"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "role": {
      "type": "string",
      "enum": [
        "SOC Analyst",
        "Threat Intelligence",
        "Incident Responder",
        "Forensics",
        "Red Team",
        "Blue Team",
        "Purple Team",
        "Cloud Security",
        "OT/ICS Security",
        "AI Security",
        "Zero Trust Engineer"
      ]
    },
    "skills": { "type": "array", "items": { "type": "string" } },
    "certifications": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Security+",
          "CySA+",
          "PenTest+",
          "CISSP",
          "CISM",
          "GIAC",
          "OSCP",
          "OSCE",
          "CCSP",
          "AWS-Security",
          "Azure-Security",
          "Google-Security"
        ]
      }
    },
    "experienceYears": { "type": "number" },
    "clearanceLevel": {
      "type": "string",
      "enum": ["none", "public-trust", "confidential", "secret", "top-secret"]
    },
    "availability": { "type": "string", "enum": ["full-time", "contract", "on-call"] },
    "remoteAllowed": { "type": "boolean" }
  }
}
