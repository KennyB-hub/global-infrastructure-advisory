      "equipmentType": null,
      "time": "1–3 days",
      "steps": [
        "Segment affected networks",
        "Isolate suspicious hosts",
        "Remove persistence mechanisms",
        "Rebuild compromised systems"
      ]
    },
    "Data Exfiltration": {
      "materials": 0,
      "materialType": null,
      "laborHours": 80,
      "equipmentDays": 0,
      "equipmentType": null,
      "time": "2–5 days",
      "steps": [
        "Block exfiltration channels",
        "Identify scope of data loss",
        "Notify required parties",
        "Implement stricter egress controls"
      ]
    }
