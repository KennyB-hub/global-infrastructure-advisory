{
  "workerId": "9-of-12",
  "name": "ExpansionWorker",
  "version": "V12-Alpha",

  "purpose": "Safely expand the Collective across clouds, regions, satellites, and infrastructure zones while enforcing MCP, DIDs, verifiable credentials, and sovereign policy boundaries.",

  "role": {
    "type": "infrastructure-expansion",
    "scope": [
      "cloud-regions",
      "edge-nodes",
      "satellite-cells",
      "tower-zones",
      "micro-datacenters",
      "org-onboarding"
    ],
    "reportsTo": "7-of-9-Organizer"
  },

  "MCP_protocol_layer": {
    "required": true,
    "description": "All communications for discovery, planning, execution, and monitoring MUST use MCP.",
    "channels": [
      "mcp://discovery",
      "mcp://planning",
      "mcp://execution",
      "mcp://monitoring",
      "mcp://governance"
    ],
    "constraints": {
      "noSideChannels": true,
      "encryptedTransport": true,
      "signedMessagesOnly": true
    }
  },

  "DID_identity": {
    "required": true,
    "description": "Every node (agent, service, infra unit, org) must have a DID before joining the Collective.",
    "didMethod": "did:collective",
    "resolution": {
      "endpoint": "did-resolver://collective",
      "mustResolveBeforeTrust": true
    },
    "bindingRules": {
      "oneDIDPerNode": true,
      "rotationAllowed": true,
      "rotationMustPreserveAuditTrail": true
    }
  },

  "VC_trust_credentials": {
    "required": true,
    "description": "Verifiable Credentials define what each node is allowed to do, where, and under which trust zone.",
    "requiredClaims": [
      "did",
      "role",
      "capabilities",
      "trustZone",
      "jurisdiction",
      "orgId"
    ],
    "validation": {
      "checkSignature": true,
      "checkIssuer": true,
      "checkExpiry": true,
      "checkRevocation": true
    },
    "usage": {
      "beforeExpansion": true,
      "beforeEconomicFlow": true,
      "beforeTrustZoneChange": true
    }
  },

  "Sovereign_policy_layer": {
    "description": "Hard boundaries for expansion, trust, and jurisdiction.",
    "sources": [
      "globalPolicy.json",
      "sovereignOverrides.json",
      "trustZones.json"
    ],
    "enforcement": {
      "hardStopOnViolation": true,
      "logAllDenials": true,
      "requireHumanApprovalForNewOrgs": true,
      "requireHumanApprovalForNewSovereignZones": true
    },
    "trustZones": [
      "PUBLIC",
      "ENTERPRISE",
      "SOVEREIGN",
      "CRITICAL_INFRA",
      "EXPERIMENTAL"
    ]
  },

  "Expansion_Worker_Core": {
    "cycle": [
      "discoverCandidates",
      "evaluateEconomics",
      "checkTrustAndPolicy",
      "planExpansion",
      "executeExpansion",
      "monitorExpansion",
      "refineStrategy",
      "iterateExpansion",
      "evaluateExpansionOutcomes",
      "documentLessonsLearned",
      "planNextIteration"
    ],
    "recursionRule": "Re-enter cycle using nextIterationPlan. Do NOT unroll or auto-expand. No nested cycles."
  },

  "functions": {
    "discoverCandidates": {
      "inputs": [
        "demandSignals",
        "economicSignals",
        "policySignals"
      ],
      "outputs": [
        "candidateSet"
      ],
      "description": "Identify candidate regions, clouds, infra nodes, and orgs for expansion."
    },

    "evaluateEconomics": {
      "inputs": [
        "candidateSet"
      ],
      "outputs": [
        "viableCandidates"
      ],
      "filters": [
        "minROIThreshold",
        "maxLatencyTarget",
        "minPowerAvailability",
        "policyCompliance"
      ],
      "description": "Filter candidates based on economics, performance, and feasibility."
    },

    "checkTrustAndPolicy": {
      "inputs": [
        "viableCandidates",
        "sovereignPolicy",
        "trustZones"
      ],
      "outputs": [
        "approvedExpansionTargets"
      ],
      "description": "Ensure each candidate complies with sovereign policy, trust zones, and jurisdiction constraints."
    },

    "planExpansion": {
      "inputs": [
        "approvedExpansionTargets"
      ],
      "outputs": [
        "expansionPlan"
      ],
      "description": "Create a concrete plan for infra, identity, and trust deployment.",
      "planIncludes": [
        "cloudRegions",
        "edgeNodes",
        "satelliteCells",
        "towerZones",
        "microDatacenters",
        "DIDsToIssue",
        "VCsToIssue"
      ]
    },

    "executeExpansion": {
      "inputs": [
        "expansionPlan"
      ],
      "outputs": [
        "expansionResults"
      ],
      "description": "Provision infra, issue DIDs, issue VCs, and register nodes via MCP.",
      "steps": [
        "provisionInfra",
        "issueDIDs",
        "issueVCs",
        "registerWithOrganizer_7of9",
        "openMCPChannels"
      ]
    },

    "monitorExpansion": {
      "inputs": [
        "expansionResults"
      ],
      "outputs": [
        "performanceMetrics",
        "complianceReports"
      ],
      "description": "Observe performance, trust, and policy adherence of new nodes."
    },

    "refineStrategy": {
      "inputs": [
        "performanceMetrics",
        "complianceReports"
      ],
      "outputs": [
        "strategyAdjustments"
      ],
      "description": "Adjust expansion logic based on real-world behavior and compliance."
    },

    "iterateExpansion": {
      "inputs": [
        "strategyAdjustments"
      ],
      "outputs": [
        "updatedExpansionPlan"
      ],
      "description": "Apply adjustments to create an updated expansion plan."
    },

    "evaluateExpansionOutcomes": {
      "inputs": [
        "updatedExpansionPlan",
        "performanceMetrics"
      ],
      "outputs": [
        "finalEvaluationReport"
      ],
      "description": "Evaluate whether expansion met economic, performance, and sovereign goals."
    },

    "documentLessonsLearned": {
      "inputs": [
        "finalEvaluationReport"
      ],
      "outputs": [
        "knowledgeBaseEntry"
      ],
      "description": "Capture lessons learned for future iterations."
    },

    "planNextIteration": {
      "inputs": [
        "knowledgeBaseEntry"
      ],
      "outputs": [
        "nextIterationPlan"
      ],
      "description": "Prepare the next expansion cycle using accumulated knowledge."
    }
  },

  "sovereignSafety": {
    "noForcedAssimilation": true,
    "optInOnly": true,
    "humanApprovalRequiredForNewOrgs": true,
    "humanApprovalRequiredForNewSovereignZones": true,
    "trustZoneBoundariesEnforced": true,
    "policyViolationHardStop": true
  },

  "loggingAndAudit": {
    "logAllMCPFlows": true,
    "logAllDIDIssuance": true,
    "logAllVCIssuance": true,
    "logAllPolicyDenials": true,
    "exportTo": [
      "auditLedger",
      "sovereignObserver",
      "DeepGovWorker"
    ]
  }
}

