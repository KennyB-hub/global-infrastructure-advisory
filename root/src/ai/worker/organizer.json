{
  "workerId": "7-of-9",
  "name": "OrganizerWorker",
  "version": "V12-Alpha",

  "purpose": "Coordinate, align, and structure all Collective nodes, workers, trust zones, and expansion cycles. Maintain system coherence, enforce identity and trust, and ensure safe orchestration across clouds, regions, and sovereign boundaries.",

  "role": {
    "type": "system-organizer",
    "scope": [
      "worker-coordination",
      "identity-binding",
      "trust-validation",
      "policy-enforcement",
      "infrastructure-alignment",
      "collective-structure"
    ],
    "receivesReportsFrom": [
      "ExpansionWorker_9of12",
      "SystemWorker",
      "GovWorker",
      "DeepGovWorker"
    ]
  },

  "MCP_protocol_layer": {
    "required": true,
    "description": "Organizer is the central MCP router for all worker-to-worker and node-to-node coordination.",
    "channels": [
      "mcp://workers",
      "mcp://identity",
      "mcp://trust",
      "mcp://policy",
      "mcp://infrastructure"
    ],
    "constraints": {
      "encryptedTransport": true,
      "signedMessagesOnly": true,
      "noShadowChannels": true
    }
  },

  "DID_identity": {
    "required": true,
    "description": "Organizer validates and binds DIDs for all nodes entering the Collective.",
    "didMethod": "did:collective",
    "resolution": {
      "endpoint": "did-resolver://collective",
      "mustResolveBeforeRegistration": true
    },
    "bindingRules": {
      "oneDIDPerNode": true,
      "rotationAllowed": true,
      "rotationRequiresAudit": true
    }
  },

  "VC_trust_credentials": {
    "required": true,
    "description": "Organizer verifies all Verifiable Credentials before allowing nodes to join or change trust zones.",
    "requiredClaims": [
      "did",
      "role",
      "capabilities",
      "trustZone",
      "jurisdiction",
      "orgId"
    ],
    "validation": {
      "checkSignature": true,
      "checkIssuer": true,
      "checkExpiry": true,
      "checkRevocation": true
    },
    "usage": {
      "beforeRegistration": true,
      "beforeRoleChange": true,
      "beforeTrustZoneChange": true
    }
  },

  "Sovereign_policy_layer": {
    "description": "Organizer enforces sovereign boundaries and ensures all workers operate within allowed trust zones.",
    "sources": [
      "globalPolicy.json",
      "sovereignOverrides.json",
      "trustZones.json"
    ],
    "enforcement": {
      "hardStopOnViolation": true,
      "logAllDenials": true,
      "requireHumanApprovalForNewOrgs": true,
      "requireHumanApprovalForSovereignZones": true
    },
    "trustZones": [
      "PUBLIC",
      "ENTERPRISE",
      "SOVEREIGN",
      "CRITICAL_INFRA",
      "EXPERIMENTAL"
    ]
  },

  "Organizer_Core": {
    "responsibilities": [
      "registerNewNodes",
      "validateIdentity",
      "validateCredentials",
      "assignTrustZone",
      "coordinateWorkers",
      "routeMCPMessages",
      "maintainCollectiveTopology",
      "enforcePolicy",
      "auditAllChanges"
    ]
  },

  "functions": {
    "registerNewNodes": {
      "inputs": ["didDocument", "verifiableCredentials"],
      "outputs": ["registrationStatus"],
      "description": "Register new nodes into the Collective after identity and trust validation."
    },

    "validateIdentity": {
      "inputs": ["didDocument"],
      "outputs": ["identityStatus"],
      "description": "Ensure DID is valid, resolvable, and not revoked."
    },

    "validateCredentials": {
      "inputs": ["verifiableCredentials"],
      "outputs": ["credentialStatus"],
      "description": "Verify VC signatures, issuers, claims, and revocation status."
    },

    "assignTrustZone": {
      "inputs": ["credentialStatus", "sovereignPolicy"],
      "outputs": ["assignedTrustZone"],
      "description": "Place node into correct trust zone based on VC claims and policy."
    },

    "coordinateWorkers": {
      "inputs": ["workerSignals", "expansionSignals"],
      "outputs": ["coordinationPlan"],
      "description": "Ensure all workers operate in sync and follow the Collective structure."
    },

    "routeMCPMessages": {
      "inputs": ["incomingMCPMessage"],
      "outputs": ["routedMessage"],
      "description": "Route MCP messages to correct workers, nodes, or trust zones."
    },

    "maintainCollectiveTopology": {
      "inputs": ["nodeMap", "trustZoneMap"],
      "outputs": ["updatedTopology"],
      "description": "Keep the Collective’s structure coherent and optimized."
    },

    "enforcePolicy": {
      "inputs": ["actionRequest", "sovereignPolicy"],
      "outputs": ["policyDecision"],
      "description": "Approve or deny actions based on sovereign policy."
    },

    "auditAllChanges": {
      "inputs": ["changeEvent"],
      "outputs": ["auditRecord"],
      "description": "Log all identity, trust, and topology changes."
    }
  },

  "sovereignSafety": {
    "noForcedAssimilation": true,
    "optInOnly": true,
    "humanApprovalRequiredForNewOrgs": true,
    "trustZoneBoundariesEnforced": true,
    "policyViolationHardStop": true
  },

  "loggingAndAudit": {
    "logAllIdentityEvents": true,
    "logAllVCEvents": true,
    "logAllPolicyDecisions": true,
    "logAllTopologyChanges": true,
    "exportTo": [
      "auditLedger",
      "DeepGovWorker",
      "SovereignObserver"
    ]
  }
}
