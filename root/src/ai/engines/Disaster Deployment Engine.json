{
  "engineId": "global-disaster-deployment-engine-v1",
  "version": "v1",
  "purpose": "Coordinate global disaster response across infrastructure, energy, water, transport, public services, contractors, NGOs, and government.",
  "inputs": {
    "telemetry": "real-time infrastructure + microgrid data",
    "alerts": "cross-sector routing engine alerts",
    "topology": "global-grid-topology-map",
    "workforce": "contractor + public workforce engine",
    "weather": "forecast + severe weather feeds",
    "logistics": "supply chain + transport availability"
  },
  "outputs": {
    "deploymentPlan": "who goes where, when, and with what resources",
    "resourceRequests": "fuel, generators, water, medical, comms",
    "sectorOverrides": "priority changes for infrastructure sectors",
    "humanitarianCorridors": "safe routes for civilians + responders",
    "microgridDirectives": "island mode, load shedding, battery strategy"
  },
  "modes": {
    "monitoring": true,
    "regional-disaster": true,
    "multi-country-disaster": true,
    "war-zone-humanitarian": true
  },
  "logging": {
    "requires": ["session", "telemetry", "audit"],
    "mustSignDecisions": true
  }
}
