/* GLOBAL INFRASTRUCTURE FIELDS STYLES */

.gif-section {
  padding: 4rem 1.5rem;
  background: #05060a;
  color: #f5f5f7;
}

.gif-container {
  max-width: 1200px;
  margin: 0 auto;
}

.gif-header {
  max-width: 720px;
  margin: 0 auto 3rem auto;
  text-align: center;
}

.gif-header h2 {
  font-size: 2.2rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.gif-header p {
  font-size: 1rem;
  line-height: 1.6;
  color: #b3b7c5;
}

.gif-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1.75rem;
}

.gif-card {
  background: #0c0e16;
  border-radius: 0.9rem;
  padding: 1.5rem 1.4rem 1.6rem;
  border: 1px solid rgba(255, 255, 255, 0.04);
  box-shadow: 0 14px 30px rgba(0, 0, 0, 0.45);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.gif-card h3 {
  font-size: 1.05rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 0.4rem;
}

.gif-tagline {
  font-size: 0.9rem;
  color: #9ca3b5;
  margin-bottom: 0.9rem;
}

.gif-card ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.gif-card li {
  font-size: 0.9rem;
  line-height: 1.5;
  color: #d4d7e3;
  margin-bottom: 0.35rem;
  position: relative;
  padding-left: 1.1rem;
}

.gif-card li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.55rem;
  width: 6px;
  height: 6px;
  border-radius: 999px;
  background: linear-gradient(135deg, #4ade80, #22c55e);
}

/* Hover / focus states */

.gif-card:hover {
  border-color: rgba(74, 222, 128, 0.4);
  transform: translateY(-3px);
  transition: all 0.18s ease-out;
}

/* Responsive layout */

@media (max-width: 1100px) {
  .gif-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media (max-width: 900px) {
  .gif-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 640px) {
  .gif-section {
    padding: 3rem 1.25rem;
  }

  .gif-grid {
    grid-template-columns: 1fr;
  }

  .gif-header h2 {
    font-size: 1.7rem;
  }
}
