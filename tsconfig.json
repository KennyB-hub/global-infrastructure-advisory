{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,                     /* Crucial: Allows JS and TS to live together */
    "checkJs": false,                    /* Skips type checking legacy JS files */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@seven-os/*": ["./seven-os/*"],
      "@ai-engines/*": ["./ai-engines/*"],
      "@autonomous/*": ["./seven-os/autonomous/*"],
      "@runtime/*": ["./seven-runtime/*"],
      "@proprietary-cli/*": ["./proprietary-cli/*"],
      "@scripts/*": ["./scripts/*"],
      "@config/*": ["./seven-os/config/*"],
      "@data/*": ["./data/*"],
      
      /* Dynamic Fallback Path Bridges for Legacy Imports */
      "autonomous/*": ["./seven-os/autonomous/*"],
      "config/*": ["./seven-os/config/*"],
      "data/*": ["./data/*"]
    },
     "exclude": ["node_modules", "dist"]
  }
}

