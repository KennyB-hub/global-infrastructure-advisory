{
    "version": "0.2.0",
    "configurations": [

        // --- 1. Attach to Microsoft Edge ---
        {
            "name": "[Attach_to_Edge](ca://s?q=Attach_to_Edge)",
            "type": "msedge",
            "request": "attach",
            "port": 9222,
            "webRoot": "${workspaceFolder}"
        },

        // --- 2. Launch Microsoft Edge (local dev site) ---
        {
            "name": "[Launch_Edge](ca://s?q=Launch_Edge)",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        },

        // --- 3. Frontend Dev Server (Vite / Next / SvelteKit) ---
        {
            "name": "[Frontend_Dev_Server](ca://s?q=Frontend_Dev_Server)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/.bin/vite",
            "args": ["--host"],
            "cwd": "${workspaceFolder}",
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 4. Launch Node Program (generic runner) ---
        {
            "name": "[Launch_Node_Program](ca://s?q=Launch_Node_Program)",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 5. Cloudflare Worker Debug (Wrangler) ---
        {
            "name": "[Debug_Cloudflare_Worker](ca://s?q=Debug_Cloudflare_Worker)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": ["wrangler", "dev", "--inspect"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 6. Wrangler Dev (no inspector) ---
        {
            "name": "[Wrangler_Dev](ca://s?q=Wrangler_Dev)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": ["wrangler", "dev"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 7. AI Sandbox Execution ---
        {
            "name": "[AI_Sandbox_Runner](ca://s?q=AI_Sandbox_Runner)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/sandbox/run-sandbox.js",
            "cwd": "${workspaceFolder}",
            "env": {
                "AI_SANDBOX": "true",
                "NODE_ENV": "development"
            },
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 8. Cloudflare API Test Runner ---
        {
            "name": "[Cloudflare_API_Tests](ca://s?q=Cloudflare_API_Tests)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/cloudflare-tests.js",
            "cwd": "${workspaceFolder}",
            "env": {
                "CF_API_TOKEN": "${env:CF_API_TOKEN}"
            },
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 9. Schema Guard (AI Output Validation) ---
        {
            "name": "[Validate_AI_Output](ca://s?q=Validate_AI_Output)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/src/ai/validation/schema-guard.js",
            "cwd": "${workspaceFolder}",
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 10. Decision Engine (AI Brainstem) ---
        {
            "name": "[Debug_Decision_Engine](ca://s?q=Debug_Decision_Engine)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/src/ai/decision-engine.js",
            "cwd": "${workspaceFolder}",
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 11. AI Workflow Engine ---
        {
            "name": "[Run_AI_Workflow](ca://s?q=Run_AI_Workflow)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/src/ai/workflow/index.js",
            "cwd": "${workspaceFolder}",
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 12. Geo Engine ---
        {
            "name": "[Debug_Geo_Engine](ca://s?q=Debug_Geo_Engine)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/backend/utilities/dns/geo/geo-logic/geo-engine.js",
            "cwd": "${workspaceFolder}",
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 13. Matching Engine ---
        {
            "name": "[Debug_Matching_Engine](ca://s?q=Debug_Matching_Engine)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/backend/matching/test-matching.js",
            "cwd": "${workspaceFolder}",
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 14. Schema Registry ---
        {
            "name": "[Debug_Schema_Registry](ca://s?q=Debug_Schema_Registry)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/backend/data/schema-registry.js",
            "cwd": "${workspaceFolder}",
            "skipFiles": ["<node_internals>/**"]
        }
    ]
}
