{
    "version": "0.2.0",
    "configurations": [

        // --- 1. Attach to Microsoft Edge ---
        {
            "name": "Attach to Edge",
            "type": "msedge",
            "request": "attach",
            "port": 9222,
            "webRoot": "${workspaceFolder}"
        },

        // --- 2. Launch Microsoft Edge (local dev site) ---
        {
            "name": "Launch Edge",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        },

        // --- 3. Launch Node Program (AI tools, scripts, engines) ---
        {
            "name": "Launch Node Program",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 4. Cloudflare Workers Debug (Wrangler) ---
        {
            "name": "Debug Cloudflare Worker",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": ["wrangler", "dev", "--inspect"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 5. AI Sandbox Execution (safe environment) ---
        {
            "name": "AI Sandbox Runner",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/sandbox/run-sandbox.js",
            "cwd": "${workspaceFolder}",
            "env": {
                "AI_SANDBOX": "true",
                "NODE_ENV": "development"
            },
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 6. Cloudflare API Test Runner ---
        {
            "name": "Cloudflare API Tests",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/cloudflare-tests.js",
            "cwd": "${workspaceFolder}",
            "env": {
                "CF_API_TOKEN": "${env:CF_API_TOKEN}"
            },
            "skipFiles": ["<node_internals>/**"]
        },

        // --- 7. Deep Mind Decision Engine Debug ---
        {
            "name": "Debug Decision Engine",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/src/ai/decision-engine.js",
            "cwd": "${workspaceFolder}",
            "skipFiles": ["<node_internals>/**"]
        }
    ]
}
