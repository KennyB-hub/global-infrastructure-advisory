{
    "version": "2.0.0",
    "tasks": [

        // --- 1. Run Local Dev Server (Frontend / Public Layer) ---
        {
            "label": "Run Dev Server",
            "type": "shell",
            "command": "npm run dev",
            "group": "build",
            "problemMatcher": []
        },

        // --- 2. Run Cloudflare Worker in Dev Mode ---
        {
            "label": "Wrangler Dev",
            "type": "shell",
            "command": "npx wrangler dev",
            "group": "build",
            "problemMatcher": []
        },

        // --- 3. Run Cloudflare Worker with Inspector (AI Debugging) ---
        {
            "label": "Wrangler Dev Inspect",
            "type": "shell",
            "command": "npx wrangler dev --inspect",
            "group": "build",
            "problemMatcher": []
        },

        // --- 4. Cloudflare API Test Suite ---
        {
            "label": "Cloudflare API Tests",
            "type": "node",
            "command": "node",
            "args": [
                "scripts/cloudflare-tests.js"
            ],
            "options": {
                "env": {
                    "CF_API_TOKEN": "${env:CF_API_TOKEN}"
                }
            },
            "problemMatcher": []
        },

        // --- 5. AI Sandbox Execution (Safe Environment) ---
        {
            "label": "Run AI Sandbox",
            "type": "node",
            "command": "node",
            "args": [
                "sandbox/run-sandbox.js"
            ],
            "options": {
                "env": {
                    "AI_SANDBOX": "true",
                    "NODE_ENV": "development"
                }
            },
            "problemMatcher": []
        },

        // --- 6. Validate AI Output (Schema Guard) ---
        {
            "label": "Validate AI Output",
            "type": "node",
            "command": "node",
            "args": [
                "src/ai/validation/schema-guard.js"
            ],
            "problemMatcher": []
        },

        // --- 7. Run Decision Engine (AI Brainstem) ---
        {
            "label": "Run Decision Engine",
            "type": "node",
            "command": "node",
            "args": [
                "src/ai/decision-engine.js"
            ],
            "problemMatcher": []
        },

        // --- 8. Run AI Workflow Tests ---
        {
            "label": "Run AI Workflow",
            "type": "node",
            "command": "node",
            "args": [
                "src/ai/workflow/index.js"
            ],
            "problemMatcher": []
        }
    ]
}
