{
  "name": "gia-worker",
  "main": "src/index.ts",
  "compatibility_date": "2024-04-03",
  "routes": [
    {
      "pattern": "4882dee7.global-infrastructure-advisory.pages.dev/*"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "A_TEAM_STORAGE",
      "id": "fany-unit-1831"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "intelligence-service",
      "database_id": "PASTE_YOUR_D1_ID_HERE"
    }
  ]
}
  
