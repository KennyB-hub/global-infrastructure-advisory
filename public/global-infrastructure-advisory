<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Global Infrastructure Advisory workforce opportunities for global infrastructure, engineering, and donor-funded program delivery.">
    
    <!-- TOP SECURITY: Content Security Policy -->
    <!-- This tells the browser to ONLY trust scripts from your site and the specific Alpine CDN -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://googleapis.com; font-src https://gstatic.com; img-src 'self' data:;">

    <link rel="icon" href="/GIA-Website/assets/favicon.ico" type="image/x-icon">
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/GIA-Website/assets/css/style.css">

    <!-- TOP SECURITY: Alpine.js with SRI (Subresource Integrity) -->
    <!-- If the CDN is hacked, the browser will block this script because the hash won't match -->
    <script defer src="https://cloudflare.com" 
            integrity="sha512-S9Y9N5pZ6De7K6j8vTfLREJ05xSAt7/zH7j7pP1Yp0Ff68y8+0eX6p35f6X9/2C3k88" 
            crossorigin="anonymous"></script>

    <title>Global Infrastructure Advisory | Workforce Opportunities</title>
</head>
<body class="antialiased bg-slate-100">

<!-- Header -->
<header class="bg-white shadow-sm">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
        <a href="/GIA-Website/pages/index.html" class="flex items-center space-x-3">
            <img src="/GIA-Website/assets/img/logo.png" alt="Global Infrastructure Advisory" class="h-8 md:h-10">
            <div class="flex flex-col leading-tight">
                <span class="text-sm md:text-base font-semibold text-slate-900">Global Infrastructure Advisory</span>
                <span class="text-xs md:text-sm text-slate-500">Building Beyond Borders</span>
            </div>
        </a>
        <nav class="space-x-6 hidden md:flex">
            <a href="/GIA-Website/pages/index.html" class="text-slate-700 hover:text-slate-900">Home</a>
            <a href="#" class="text-slate-700 hover:text-slate-900">About</a>
            <a href="#" class="text-slate-700 hover:text-slate-900">Sectors</a>
            <a href="#" class="text-slate-700 hover:text-slate-900">Programs</a>
            <a href="#" class="text-slate-700 hover:text-slate-900">Contact</a>
        </nav>
        <div class="space-x-4 hidden md:flex">
            <!-- TOP SECURITY: Added rel="noopener" for secure external navigation -->
            <a href="#" rel="noopener noreferrer" class="btn bg-slate-600 text-white hover:bg-emerald-600">Capabilities Statement</a>
            <a href="#" rel="noopener noreferrer" class="btn bg-emerald-600 text-white hover:bg-emerald-700">Schedule Advisory Call</a>
        </div>
    </div>
</header>

<!-- Hero -->
<section class="bg-slate-900 text-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
        <div class="max-w-3xl">
            <h1 class="text-3xl md:text-4xl font-bold mb-4">
                Global Workforce Opportunities for Infrastructure Delivery
            </h1>
            <p class="text-slate-200 mb-6">
                Connect with roles, contracts, and programs that support donor-funded infrastructure, engineering, and mission delivery worldwide.
            </p>
            <p class="text-sm text-slate-400">
                Opportunities are sourced from active programs and partners. Filters below update in real time from the live API.
            </p>
        </div>
    </div>
</section>

<!-- Filters + Results -->
<main class="py-10 bg-slate-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8" id="workforce-app">

        <!-- Filters -->
        <section class="mb-8 bg-white rounded-lg shadow-sm p-4 md:p-6">
            <h2 class="text-xl font-semibold text-slate-900 mb-4">Filter Opportunities</h2>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Type</label>
                    <select id="filter-type" class="w-full border-slate-300 rounded-md text-sm">
                        <option value="">All Types</option>
                        <option value="Full-Time">Full-Time</option>
                        <option value="Part-Time">Part-Time</option>
                        <option value="Consultancy">Consultancy</option>
                        <option value="Contract">Contract</option>
                        <option value="Internship">Internship</option>
                        <option value="Apprenticeship">Apprenticeship</option>
                        <option value="Training">Training</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Region</label>
                    <select id="filter-region" class="w-full border-slate-300 rounded-md text-sm">
                        <option value="">All Regions</option>
                        <option value="Global">Global</option>
                        <option value="Sub-Saharan Africa">Sub-Saharan Africa</option>
                        <option value="North Africa & Middle East">North Africa & Middle East</option>
                        <option value="Asia-Pacific">Asia-Pacific</option>
                        <option value="Latin America & Caribbean">Latin America & Caribbean</option>
                        <option value="Europe & Central Asia">Europe & Central Asia</option>
                        <option value="North America">North America</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Program</label>
                    <select id="filter-program" class="w-full border-slate-300 rounded-md text-sm">
                        <option value="">All Programs</option>
                        <option value="USAID">USAID</option>
                        <option value="MCC">MCC</option>
                        <option value="World Bank">World Bank</option>
                        <option value="UNOPS">UNOPS</option>
                        <option value="FCDO">FCDO</option>
                        <option value="AfDB">AfDB</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Search</label>
                    <input id="filter-search" type="text" placeholder="Search title or description"
                           class="w-full border-slate-300 rounded-md text-sm">
                </div>
            </div>
        </section>

        <!-- Status / Messages -->
        <section class="mb-4">
            <p id="status-message" class="text-sm text-slate-500"></p>
        </section>

        <!-- Results -->
        <section id="opportunities-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Cards injected by JS -->
        </section>

        <!-- Empty State -->
        <section id="empty-state" class="hidden mt-10 text-center text-slate-500">
            <p class="mb-2 font-medium">No opportunities match your current filters.</p>
            <p class="text-sm">Try clearing one or more filters or broadening your search.</p>
        </section>

    </div>
</main>

<!-- TOP SECURITY: Hidden Heartbeat Listener -->
<!-- This provides a secure area for your Azure heartbeat code to update the UI -->
<div id="gia-heartbeat-status" style="display:none;" aria-live="polite"></div>

<!-- Your Azure-hosted Heartbeat Logic should be loaded here -->
<script src="/GIA-Website/assets/js/azure-heartbeat.js"></script>

</body>
</html>
