[ApiController]
[Route("api/enforcement")]
public sealed class EnforcementController : ControllerBase
{
    private readonly IEnforcementEngine _engine;

    public EnforcementController(IEnforcementEngine engine)
    {
        _engine = engine;
    }

    [HttpPost("evaluate")]
    public async Task<ActionResult<EnforcementResponse>> Evaluate(
        [FromBody] EnforcementRequest request,
        CancellationToken cancellationToken)
    {
        var response = await _engine.EvaluateAsync(request, cancellationToken);
        return Ok(response);
    }
}
