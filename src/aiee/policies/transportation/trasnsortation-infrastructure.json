{
  "policyId": "TRANSPORT_INFRASTRUCTURE_V1",
  "name": "Transportation Infrastructure Policy Pack",
  "version": "1.0.0",
  "source": "AIEE",
  "scope": {
    "resourceTypes": ["ROAD", "BRIDGE", "TUNNEL", "RAIL_SYSTEM", "AIRPORT", "SEAPORT", "TRAFFIC_CONTROL", "LOGISTICS_CORRIDOR"],
    "actions": ["CONTROL", "MONITOR", "DISPATCH", "ROUTE", "MAINTENANCE", "SHUTOFF", "RESTRICT"],
    "trustZones": ["public", "contractor", "employee", "admin", "gov", "deepgov", "system"]
  },
  "rules": [
    {
      "ruleId": "TRANS_ROAD_001",
      "description": "Prevent unsafe road closures without authorization.",
      "condition": "action.name == \"CloseRoad\" && !actor.roles.Contains(\"TRANSPORT_ADMIN\")",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_ROAD_002",
      "description": "Road surface conditions below safety threshold require human review.",
      "condition": "data.roadConditionIndex < data.minConditionIndex",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "TRANS_BRIDGE_001",
      "description": "Prevent operations on structurally unsafe bridges.",
      "condition": "data.bridgeIntegrity < data.minIntegrity",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_BRIDGE_002",
      "description": "Bridge overload risk requires human review.",
      "condition": "data.loadPercent > data.maxLoadPercent",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "TRANS_TUNNEL_001",
      "description": "Prevent unsafe tunnel ventilation conditions.",
      "condition": "data.airQualityIndex > data.maxAirQualityIndex",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_RAIL_001",
      "description": "Prevent unsafe rail switching operations.",
      "condition": "data.switchFault == true && action.name == \"SwitchTrack\"",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_RAIL_002",
      "description": "Hazardous cargo routing requires human review.",
      "condition": "data.cargoType == \"HAZMAT\" && action.name == \"RouteTrain\"",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "TRANS_RAIL_003",
      "description": "Prevent rail operations during detected track defects.",
      "condition": "data.trackDefectDetected == true",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_AIRPORT_001",
      "description": "Runway operations require safe visibility and weather conditions.",
      "condition": "data.visibility < data.minVisibility || data.windSpeed > data.maxWindSpeed",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_AIRPORT_002",
      "description": "Critical runway closures require human review.",
      "condition": "action.name == \"CloseRunway\" && data.runwayCritical == true",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "TRANS_SEAPORT_001",
      "description": "Prevent unsafe port operations during high tide or storm surge.",
      "condition": "data.stormSurgeRisk == \"HIGH\"",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_SEAPORT_002",
      "description": "Hazardous cargo loading requires human review.",
      "condition": "data.cargoType == \"HAZMAT\" && action.name == \"LoadCargo\"",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "TRANS_TRAFFIC_001",
      "description": "Traffic signal overrides require authorized personnel.",
      "condition": "action.name == \"OverrideSignal\" && !actor.roles.Contains(\"TRAFFIC_CONTROL\")",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_TRAFFIC_002",
      "description": "Emergency vehicle routing must be prioritized.",
      "condition": "data.vehicleType == \"EMERGENCY\" && action.name == \"RouteVehicle\" && data.priority != \"HIGH\"",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_LOGISTICS_001",
      "description": "Prevent routing of heavy freight through restricted corridors.",
      "condition": "data.freightWeight > data.maxCorridorWeight && action.name == \"RouteFreight\"",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_AUTONOMOUS_001",
      "description": "Autonomous vehicle corridor operations require safe sensor conditions.",
      "condition": "data.sensorHealth < data.minSensorHealth",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_CYBER_001",
      "description": "Unauthorized remote access to transportation control systems is denied.",
      "condition": "env.clientType == \"REMOTE\" && !actor.roles.Contains(\"AUTHORIZED_REMOTE\")",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_CYBER_002",
      "description": "Critical transportation SCADA/NOC operations require gov, deepgov, or system trust zone.",
      "condition": "data.scadaCritical == true && actor.trustZone != \"gov\" && actor.trustZone != \"deepgov\" && actor.trustZone != \"system\"",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_CYBER_003",
      "description": "Anomalous behavior in transportation telemetry requires human review.",
      "condition": "data.behaviorScore > data.anomalyThreshold",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "TRANS_WORKER_001",
      "description": "Only certified transportation technicians may perform maintenance.",
      "condition": "action.name == \"MAINTENANCE\" && !actor.roles.Contains(\"TRANSPORT_TECH\")",
      "effect": "DENY"
    }
  ]
}
