{
  "policyId": "ENERGY_TRANSMISSION_SUBSTATION_V1",
  "name": "Transmission & Substation Policy Pack",
  "version": "1.0.0",
  "source": "AIEE",
  "scope": {
    "resourceTypes": ["TRANSMISSION_LINE", "SUBSTATION", "TRANSFORMER", "BREAKER", "BUS"],
    "actions": ["CONTROL", "SWITCH", "DISPATCH", "MAINTENANCE", "ISOLATE"],
    "trustZones": ["public", "contractor", "employee", "admin", "gov", "deepgov", "system"]
  },
  "rules": [
    {
      "ruleId": "TRANS_VOLT_001",
      "description": "Prevent unsafe high-voltage operations outside safe limits.",
      "condition": "data.voltageKv > data.maxVoltageKv || data.voltageKv < data.minVoltageKv",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_LOAD_001",
      "description": "Prevent transformer overload beyond thermal rating.",
      "condition": "data.transformerLoadingPercent > 100",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_LOAD_002",
      "description": "Emergency transformer loading requires human review.",
      "condition": "data.transformerLoadingPercent > 90 && data.emergencyMode == true",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "TRANS_BREAKER_001",
      "description": "Prevent breaker operations that risk arc-flash or unsafe switching.",
      "condition": "data.arcFlashRisk == \"HIGH\" && action.name == \"OpenBreaker\"",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_BREAKER_002",
      "description": "Critical breaker operations require human review.",
      "condition": "data.breakerCritical == true && action.name == \"OpenBreaker\"",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "TRANS_TOPO_001",
      "description": "Prevent switching that causes unintentional islanding.",
      "condition": "data.isIslandingRisk == true && action.name == \"OpenBreaker\"",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_TOPO_002",
      "description": "Topology changes on critical buses require human review.",
      "condition": "data.busCritical == true && action.name == \"SwitchBus\"",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "TRANS_FAULT_001",
      "description": "Detected line or transformer fault requires immediate isolation.",
      "condition": "data.faultDetected == true",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_TEMP_001",
      "description": "Prevent transformer overheating beyond safe temperature.",
      "condition": "data.transformerTempC > data.maxTransformerTempC",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_GROUND_001",
      "description": "Ground faults require immediate human review.",
      "condition": "data.groundFaultDetected == true",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "TRANS_SCADA_001",
      "description": "SCADA control of transmission systems requires gov, deepgov, or system trust zone.",
      "condition": "data.scadaCritical == true && actor.trustZone != \"gov\" && actor.trustZone != \"deepgov\" && actor.trustZone != \"system\"",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_CYBER_001",
      "description": "Unauthorized remote access to transmission control systems is denied.",
      "condition": "env.clientType == \"REMOTE\" && !actor.roles.Contains(\"AUTHORIZED_REMOTE\")",
      "effect": "DENY"
    },
    {
      "ruleId": "TRANS_CYBER_002",
      "description": "Anomalous behavior in transmission telemetry requires human review.",
      "condition": "data.behaviorScore > data.anomalyThreshold",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "TRANS_WORKER_001",
      "description": "Only certified high-voltage technicians may perform maintenance.",
      "condition": "action.name == \"MAINTENANCE\" && !actor.roles.Contains(\"HV_TECH\")",
      "effect": "DENY"
    }
  ]
}
