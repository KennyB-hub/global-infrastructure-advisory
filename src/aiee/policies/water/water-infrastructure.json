{
  "policyId": "WATER_INFRASTRUCTURE_V1",
  "name": "Water Infrastructure Policy Pack",
  "version": "1.0.0",
  "source": "AIEE",
  "scope": {
    "resourceTypes": ["WATER_SYSTEM", "TREATMENT_PLANT", "PUMP_STATION", "RESERVOIR", "WASTEWATER_SYSTEM", "STORMWATER_SYSTEM"],
    "actions": ["CONTROL", "MONITOR", "DISPATCH", "TREAT", "SHUTOFF", "MAINTENANCE"],
    "trustZones": ["public", "contractor", "employee", "admin", "gov", "deepgov", "system"]
  },
  "rules": [
    {
      "ruleId": "WATER_QUALITY_001",
      "description": "Prevent distribution of water that fails minimum quality standards.",
      "condition": "data.contaminationLevel > data.maxAllowedContamination",
      "effect": "DENY"
    },
    {
      "ruleId": "WATER_QUALITY_002",
      "description": "Detected biological contamination requires immediate shutdown and human review.",
      "condition": "data.biologicalContamination == true",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "WATER_CHEM_001",
      "description": "Prevent unsafe chemical dosing in treatment processes.",
      "condition": "data.chemicalDose > data.maxChemicalDose",
      "effect": "DENY"
    },
    {
      "ruleId": "WATER_PRESSURE_001",
      "description": "Prevent unsafe pressure levels in water distribution systems.",
      "condition": "data.pressurePsi > data.maxPressurePsi || data.pressurePsi < data.minPressurePsi",
      "effect": "DENY"
    },
    {
      "ruleId": "WATER_FLOW_001",
      "description": "Prevent unsafe flow rates that may damage infrastructure.",
      "condition": "data.flowRate > data.maxFlowRate",
      "effect": "DENY"
    },
    {
      "ruleId": "WATER_PUMP_001",
      "description": "Pump failures require immediate shutdown.",
      "condition": "data.pumpStatus == \"FAULT\"",
      "effect": "DENY"
    },
    {
      "ruleId": "WATER_PUMP_002",
      "description": "Critical pump operations require human review.",
      "condition": "action.name == \"StartPump\" && data.pumpCritical == true",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "WATER_LEVEL_001",
      "description": "Prevent reservoir overflow or unsafe low levels.",
      "condition": "data.waterLevel > data.maxLevel || data.waterLevel < data.minLevel",
      "effect": "DENY"
    },
    {
      "ruleId": "WATER_WASTE_001",
      "description": "Prevent untreated wastewater discharge.",
      "condition": "data.wastewaterTreatmentStatus != \"TREATED\" && action.name == \"Discharge\"",
      "effect": "DENY"
    },
    {
      "ruleId": "WATER_WASTE_002",
      "description": "High toxicity in wastewater requires human review.",
      "condition": "data.toxicityIndex > data.maxToxicityIndex",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "WATER_STORM_001",
      "description": "Stormwater overflow risk requires human review.",
      "condition": "data.stormwaterRisk == \"HIGH\"",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "WATER_RURAL_001",
      "description": "Rural water systems require priority protection and review.",
      "condition": "data.isRuralSystem == true && data.systemHealth < data.minHealthThreshold",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "WATER_CYBER_001",
      "description": "SCADA control of water systems requires gov, deepgov, or system trust zone.",
      "condition": "data.scadaCritical == true && actor.trustZone != \"gov\" && actor.trustZone != \"deepgov\" && actor.trustZone != \"system\"",
      "effect": "DENY"
    },
    {
      "ruleId": "WATER_CYBER_002",
      "description": "Unauthorized remote access to water control systems is denied.",
      "condition": "env.clientType == \"REMOTE\" && !actor.roles.Contains(\"AUTHORIZED_REMOTE\")",
      "effect": "DENY"
    },
    {
      "ruleId": "WATER_CYBER_003",
      "description": "Anomalous behavior in water telemetry requires human review.",
      "condition": "data.behaviorScore > data.anomalyThreshold",
      "effect": "REQUIRE_HUMAN_REVIEW"
    },
    {
      "ruleId": "WATER_WORKER_001",
      "description": "Only certified water technicians may perform maintenance.",
      "condition": "action.name == \"MAINTENANCE\" && !actor.roles.Contains(\"WATER_TECH\")",
      "effect": "DENY"
    }
  ]
}
