if (request.method === "POST" && url.pathname === "/api/deep-mind") {
  try {
    // Run the Governor BEFORE calling AI
    const allowed = await checkAILoad(env);
    if (!allowed) {
      return new Response(
        JSON.stringify({ result: "⚠️ Deep Mind throttled by AI Governor." }),
        { status: 429 }
      );
    }

    const { query } = await request.json();
    const aiResponse = await env.AI.run("@cf/google/gemma-4-26b-it", {
      prompt: `GIA System Intelligence Query: ${query}`,
      max_tokens: 512
    });

    return new Response(JSON.stringify({ result: aiResponse.response }), {
      headers: {
        "content-type": "application/json",
        "Access-Control-Allow-Origin": "*"
      }
    });

  } catch (err) {
    return new Response(
      JSON.stringify({ result: "Deep Mind offline. Verify AI binding." }),
      { status: 500 }
    );
  }
}
