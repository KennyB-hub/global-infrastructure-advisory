public sealed class EnforcementEngine : IEnforcementEngine
{
    private readonly IPolicyProvider _policyProvider;
    private readonly IExpressionEvaluator _expressionEvaluator;

    public EnforcementEngine(
        IPolicyProvider policyProvider,
        IExpressionEvaluator expressionEvaluator)
    {
        _policyProvider = policyProvider;
        _expressionEvaluator = expressionEvaluator;
    }

    public async Task<EnforcementResponse> EvaluateAsync(
        EnforcementRequest request,
        CancellationToken cancellationToken = default)
    {
        var policies = await _policyProvider.GetActivePoliciesAsync(cancellationToken);

        var applicable = policies
            .Where(p => IsInScope(p.Scope, request))
            .ToList();

        var hits = new List<PolicyHit>();
        var effects = new List<string>();

        var evalContext = BuildContextObject(request);

        foreach (var policy in applicable)
        {
            foreach (var rule in policy.Rules)
            {
                var match = _expressionEvaluator.Evaluate(rule.Condition, evalContext);
                if (!match) continue;

                hits.Add(new PolicyHit
                {
                    PolicyId = policy.PolicyId,
                    PolicyName = policy.Name,
                    RuleId = rule.RuleId,
                    Effect = rule.Effect,
                    Reason = rule.Description
                });

                effects.Add(rule.Effect);
            }
        }

        var decision = ResolveDecision(effects);

        return new EnforcementResponse
        {
            RequestId = request.RequestId,
            Decision = decision,
            PolicyHits = hits,
            Conditions = BuildConditions(decision, hits),
            Explanation = BuildExplanation(decision, hits),
            Timestamp = DateTimeOffset.UtcNow
        };
    }

    private static bool IsInScope(PolicyScope scope, EnforcementRequest request)
    {
        bool resourceMatch = scope.ResourceTypes.Length == 0
            || scope.ResourceTypes.Contains(request.Action.ResourceType, StringComparer.OrdinalIgnoreCase);

        bool actionMatch = scope.Actions.Length == 0
            || scope.Actions.Contains(request.Action.Type, StringComparer.OrdinalIgnoreCase);

        bool trustZoneMatch = scope.TrustZones.Length == 0
            || scope.TrustZones.Contains(request.Actor.TrustZone, StringComparer.OrdinalIgnoreCase);

        return resourceMatch && actionMatch && trustZoneMatch;
    }

    private static object BuildContextObject(EnforcementRequest request)
        => new
        {
            actor = request.Actor,
            action = request.Action,
            data = request.DataContext,
            ai = request.AiContext,
            env = request.Environment
        };

    private static string ResolveDecision(IReadOnlyList<string> effects)
    {
        if (effects.Contains("DENY", StringComparer.OrdinalIgnoreCase))
            return "DENY";

        if (effects.Contains("CONDITION", StringComparer.OrdinalIgnoreCase))
            return "REQUIRE_HUMAN_REVIEW";

        if (effects.Contains("ALLOW", StringComparer.OrdinalIgnoreCase))
            return "ALLOW";

        // default posture: deny if nothing matched
        return "DENY";
    }

    private static List<EnforcementCondition> BuildConditions(
        string decision,
        IReadOnlyList<PolicyHit> hits)
    {
        var conditions = new List<EnforcementCondition>();

        if (decision == "REQUIRE_HUMAN_REVIEW")
        {
            conditions.Add(new EnforcementCondition
            {
                Type = "HUMAN_REVIEW",
                Details = "Action requires human approval based on policy conditions."
            });
        }

        return conditions;
    }

    private static string BuildExplanation(
        string decision,
        IReadOnlyList<PolicyHit> hits)
    {
        if (!hits.Any())
            return "No applicable policies matched. Default decision applied.";

        var summary = string.Join("; ",
            hits.Select(h => $"{h.PolicyId}/{h.RuleId}: {h.Reason} ({h.Effect})"));

        return $"Decision: {decision}. Policy hits: {summary}.";
    }
}
