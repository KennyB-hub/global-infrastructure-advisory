public class GlobalCode
{
    public BuildingCode Building { get; set; }
    public EnergyCode Energy { get; set; }
    public WaterCode Water { get; set; }
    public TransportCode Transport { get; set; }
    public TelecomCode Telecom { get; set; }
    // extend per sector
}

public class BuildingCode
{
    public StructuralCode Structural { get; set; }
    public FireCode Fire { get; set; }
    public AccessibilityCode Accessibility { get; set; }
}

public class StructuralCode
{
    public double MaxStructuralLoad { get; set; }
    public double SeismicDesignCoefficient { get; set; }
}

public class FireCode
{
    public double MaxEgressDistance { get; set; }
    public int MinExitCount { get; set; }
}

public class AccessibilityCode
{
    public bool RequiresRamp { get; set; }
    public double MinDoorWidthInches { get; set; }
}

