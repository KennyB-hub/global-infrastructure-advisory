// unified-ux-core.ts
import { UXInput, UXResult, Persona } from "./ux-core-types";

export async function processUX(input: UXInput): Promise<UXResult> {
  const { persona, text, context = {} } = input;

  // 1. Persona → trustZone
  const trustZone = mapPersonaToTrustZone(persona);

  // 2. Infer high-level intent
  const intent = inferIntent(persona, text, context);

  // 3. Check required fields for that intent
  const missingField = findMissingField(intent, context);

  if (missingField) {
    return {
      type: "question",
      field: missingField,
      prompt: buildPromptForField(persona, intent, missingField)
    };
  }

  // 4. Build final payload for AI router
  const payload = buildPayload(persona, intent, context);

  return {
    type: "ready",
    workflow: payload.workflow,
    trustZone,
    payload,
    summary: buildHumanSummary(persona, intent, payload)
  };
}
