{
  "infrastructure_pack_id": "SEVEN-INFRA-PACK-V12",
  "version": "12.0.4",
  "description": "Unified infrastructure pack containing topology, sectors, workers, and engines for Seven‑OS V12 Alpha.",

  "platform": {
    "id": "GIA-SOVEREIGN-ALPHA",
    "system_id": "deep-mind-v12",
    "environment": "enterprise-gov",
    "failsafe_level": "AUTO_RECOVER"
  },

  "sectors": {
    "public": {},
    "contractor": {},
    "farmer": {},
    "employee": {},
    "admin": {},
    "gov": {},
    "deepgov": {},
    "system": {}
  },

  "trust_zones": {
    "public": 1,
    "internal": 2,
    "vault": 3,
    "admin": 4,
    "gov": 5,
    "deepgov": 6,
    "system": 7
  },

  "topology": {
    "nodes": {
      "gov": ["GOV_NATO"],
      "farmer": ["AGRI_INFRA"],
      "system": ["AI_LOGIC"],
      "deepgov": ["DEEP-MIND-CORE"]
    },
    "clusters": {
      "DEEP-MIND-CORE": { "sector": "deepgov", "health": 98 },
      "AI_LOGIC": { "sector": "system", "health": 96 },
      "AGRI_INFRA": { "sector": "farmer", "health": 94 },
      "GOV_NATO": { "sector": "gov", "health": 97 }
    }
  },

  "workers": {
    "index": {
      "workers": [
        "telemetry_worker",
        "event_worker",
        "task_worker",
        "queue_worker",
        "io_worker"
      ]
    }
  },

  "engines": {
    "engine-index": {
      "engines": [
        "CORE_ENGINE",
        "AI_CORTEX",
        "MAPPING_ENGINE",
        "BLUEPRINT_ENGINE",
        "DOCUMENT_ENGINE",
        "SECURITY_ENGINE",
        "GEO_ENGINE",
        "MATH_ENGINE",
        "DATA_ENGINE",
        "SCIENCE_ENGINE",
        "GEOTHERMAL_ENGINE",
        "RENEWABLES_ENGINE",
        "BUILDING_CODE_ENGINE",
        "ZONING_ENGINE",
        "SECTOR_ANALYSIS_ENGINE",
        "ENGINEERING_ENGINE",
        "MECHANICS_ENGINE"
      ]
    }
  },

  "infrastructure_packs": {
    "pack-gov": { "nodes": ["GOV_NATO"] },
    "pack-agri": { "nodes": ["AGRI_INFRA"] },
    "pack-ai": { "nodes": ["AI_LOGIC", "DEEP-MIND-CORE"] }
  },

  "endpoints": {
    "azure_math": "https://azure.net",
    "azure_geo": "https://azure.net",
    "config_service": "https://config.gia.int",
    "health_service": "https://health.gia.int",
    "analytics_service": "https://analytics.gia.int",
    "decision_engine": "/api/decision",
    "cortex": "/api/cortex",
    "deep_mind": "/api/deep-mind"
  },

  "sandbox": {
    "enabled": true,
    "mode": "validation-only",
    "max_token_budget": 500
  },

  "logging": {
    "level": "info",
    "format": "json",
    "output": "stdout",
    "rotate": {
      "enabled": true,
      "max_size": "100MB",
      "max_files": 5
    },
    "remote": {
      "enabled": true,
      "url": "https://logs.gia.int/ingest",
      "batch_size": 50,
      "flush_interval": "5s",
      "retry_policy": {
        "max_retries": 3,
        "backoff_factor": 2
      }
    }
  }
}
