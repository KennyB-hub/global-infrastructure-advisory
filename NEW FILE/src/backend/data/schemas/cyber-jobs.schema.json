{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cyber Security Job Listing",
  "description": "Schema for cyber, SOC, threat intelligence, and security engineering job listings in GIA.",
  "type": "object",
  "required": ["id", "title", "sector", "clearanceLevel", "skills", "responsibilities"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "sector": {
      "type": "string",
      "enum": [
        "cyber",
        "cloud",
        "telecom",
        "energy",
        "transport",
        "water",
        "health",
        "education",
        "finance",
        "government"
      ]
    },
    "clearanceLevel": {
      "type": "string",
      "enum": ["none", "public-trust", "confidential", "secret", "top-secret"]
    },
    "jobType": {
      "type": "string",
      "enum": ["full-time", "contract", "internship", "apprenticeship"]
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "certifications": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Security+",
          "Network+",
          "CySA+",
          "PenTest+",
          "CASP+",
          "CEH",
          "CISSP",
          "CISM",
          "GIAC",
          "OSCP",
          "OSCE",
          "CCSP",
          "AWS-Security",
          "Azure-Security",
          "Google-Professional-Security"
        ]
      }
    },
    "responsibilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "experienceRequired": { "type": "string" },
    "remoteAllowed": { "type": "boolean" },
    "onCallRequired": { "type": "boolean" },
    "sectorClearanceRequired": { "type": "boolean" },
    "tools": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "SIEM",
          "EDR",
          "SOAR",
          "IDS/IPS",
          "ThreatIntel",
          "Forensics",
          "CloudSecurity",
          "ZeroTrust",
          "IAM",
          "PKI",
          "Firewall",
          "OT/ICS",
          "AI-Security"
        ]
      }
    },
    "postedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" }
  }
}
