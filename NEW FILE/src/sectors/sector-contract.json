{
  "sectorId": "",
  "sectorName": "",
  "version": "v1",
  "trustZone": "infrastructure",

  "capabilities": {
    "supportsMicrogrids": true,
    "supportsRuralNodes": true,
    "supportsUrbanNodes": true,
    "supportsOfflineMode": true,
    "supportsAutonomousRepair": true
  },

  "endpoints": {
    "ingest": "/api/sector/{sectorId}/ingest",
    "status": "/api/sector/{sectorId}/status",
    "logs": "/api/sector/{sectorId}/logs",
    "dispatch": "/api/sector/{sectorId}/dispatch",
    "telemetry": "/api/sector/{sectorId}/telemetry"
  },

  "engines": {
    "core": [
      "mapping-engine",
      "data-engine",
      "logic-engine"
    ],
    "infrastructure": [
      "renewables-engine",
      "geothermal-engine",
      "building-code-engine",
      "zoning-engine",
      "engineering-engine",
      "mechanics-engine"
    ],
    "microgrid": [
      "load-balancing-engine",
      "grid-stability-engine",
      "energy-routing-engine"
    ]
  },

  "logging": {
    "requiredLogTypes": [
      "session",
      "telemetry",
      "audit",
      "memory"
    ],
    "ingestionWorker": "log-ingestion-worker",
    "schema": "src/ai/logs/log-schema.json"
  },

  "health": {
    "healthCheckEndpoint": "/api/sector/{sectorId}/health",
    "requiresLogHealthCheck": true,
    "requiresTelemetry": true,
    "requiresNodeHeartbeat": true
  },

  "security": {
    "policyProfile": "infrastructure-sector",
    "requiresAuditSigning": true,
    "requiresThreatMonitoring": true
  },

  "workforce": {
    "supportsLocalContractors": true,
    "supportsRemoteDispatch": true,
    "supportsTrainingPipelines": true,
    "requiredRoles": [
      "field-tech",
      "grid-operator",
      "contractor",
      "inspector"
    ]
  },

  "microgrid": {
    "supportsIslandMode": true,
    "supportsGridSync": true,
    "supportsLoadShedding": true,
    "supportsBatteryStorage": true,
    "supportsRenewableMixing": true
  },

  "rural": {
    "supportsLowConnectivity": true,
    "supportsOfflineCaching": true,
    "supportsDelayedSync": true,
    "supportsLocalNodeFallback": true
  }
}
